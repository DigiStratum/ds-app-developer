  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digistratum/ds-app-skeleton.git",
    "directory": "packages/ds-cdk"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.120.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "aws-cdk-lib": "^2.120.0",
    "constructs": "^10.3.0",
    "typescript": "^5.3.0"
  }
}
