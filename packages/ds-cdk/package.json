{
  "name": "@digistratum/ds-cdk",
  "version": "0.1.0",
  "description": "Reusable AWS CDK constructs for DigiStratum applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
