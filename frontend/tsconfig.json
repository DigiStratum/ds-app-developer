{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@digistratum/appshell": ["../components/appshell/index.ts"],
      "@digistratum/appshell/*": ["../components/appshell/*"],
      "@digistratum/ds-core": ["../packages/ds-core/src"],
      "@digistratum/ds-core/*": ["../packages/ds-core/src/*"],
      "@digistratum/layout": ["../components/layout-compat.ts"],
      "@digistratum/layout/*": ["../components/appshell/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
